cts\\kevinjobs.github.io\\src\\Pages\\index.js",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Exam\\index.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Calendar\\index.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\About\\index.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Homepage\\index.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Gallery\\index.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Exam\\Subject.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Exam\\ChapterCard.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Homepage\\Carousel\\index.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Gallery\\Desktop.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Exam\\QuestionCard\\index.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Homepage\\Article\\index.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Common\\DesktopNavbar\\index.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Apis\\image.js",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Gallery\\Masonry.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Gallery\\ImageFloatCard.tsx",["213"],"import React from 'react';\r\nimport { ImageType } from '../Types';\r\n\r\nimport {\r\n  CameraFilled,\r\n  CompassFilled,\r\n  BulbFilled,\r\n  SkinFilled,\r\n  VideoCameraFilled,\r\n  CloseCircleOutlined,\r\n  EnvironmentFilled,\r\n  CalendarFilled\r\n} from '@ant-design/icons';\r\n\r\ntype Props = {\r\n  isShow: boolean,\r\n  image: ImageType,\r\n  close?: any,\r\n  type?: 'desktop' | 'mobile'\r\n}\r\n\r\nconst ImageFloatCard: React.FC<Props> = (props: Props) => {\r\n  const { image } = props;\r\n\r\n  const cardStyle = {\r\n    display: props.isShow ? 'flex' : 'none',\r\n    flexWrap: props.type === 'mobile' ? 'wrap' : 'nowrap',\r\n    position: 'fixed',\r\n    top: '50%',\r\n    left: '50%',\r\n    transform: 'translateX(-50%) translateY(-50%)',\r\n    maxWidth: '90%',\r\n    height: 'auto',\r\n    maxHeight: '95%',\r\n    zIndex: 3,\r\n    width: 1400,\r\n    backgroundColor: '#fff',\r\n    borderRadius: 5\r\n  } as React.CSSProperties;\r\n\r\n  const imgStyle = {\r\n    flexGrow: 1,\r\n    borderRadius: 5,\r\n    backgroundColor: 'rgba(0,0,0,.75)',\r\n    display: 'flex',\r\n    justifyContent: 'center',\r\n    alignItems: 'center',\r\n    color: '#f1f1f1'\r\n  } as React.CSSProperties;\r\n\r\n  const infoStyle = {\r\n    width: 1000,\r\n    padding: '20px 30px',\r\n    borderRadius: 'inherit',\r\n    overflowY: 'scroll',\r\n    lineHeight: props.type === 'mobile' ? 1.2 : 1.5,\r\n    backgroundColor: '#e9e9e9'\r\n  } as React.CSSProperties;\r\n\r\n  const commentStyle = {\r\n    zIndex: 4,\r\n    borderRadius: 10,\r\n    padding: 10\r\n  } as React.CSSProperties;\r\n\r\n  const baseUrl = 'https://mintforge-1252473272.cos.ap-nanjing.myqcloud.com/image/';\r\n\r\n  const handleClick = (e: React.MouseEvent<HTMLElement>) => {\r\n    const { close } = props;\r\n    if (close) {\r\n      (close as React.MouseEventHandler<HTMLElement>)(e);\r\n    }\r\n  }\r\n\r\n  return(\r\n    <div className=\"image-float-card\"\r\n      style={cardStyle}\r\n    >\r\n      <div className=\"image-float-card__image\" style={imgStyle}>\r\n        <div style={{textAlign:'right',fontSize:20}} onClick={handleClick.bind(this)}>\r\n          <CloseCircleOutlined style={{cursor:'pointer',position:'absolute',top:10,left:10,color:'inherit'}} />\r\n        </div>\r\n        <img\r\n          src={baseUrl + image.source.replace('JPG', 'jpg')}\r\n          alt={image.title}\r\n          style={{maxWidth:'100%',maxHeight:'100%',borderRadius:5}}\r\n        />\r\n      </div>\r\n      <div className=\"image-float-card__info no-scroll-bar\" style={infoStyle}>\r\n        <h2>{image.title || '我们向往未知'}</h2>\r\n        <p>{image.desc || '这是未知的世界'}</p>\r\n        <p><SkinFilled /> {image.author}</p>\r\n        <p><BulbFilled /> {image.exposure_time}</p>\r\n        <p><VideoCameraFilled /> {image.iso} (ISO)</p>\r\n        <p><CameraFilled /> {image.manufacturer}</p>\r\n        <p><CompassFilled /> {image.position.split('|')[0] || '未知地点'}</p>\r\n        <p><EnvironmentFilled /> {image.position.split('|')[1] || '未知景点'}</p>\r\n        <p><CalendarFilled /> {image.create_time}</p>\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n\r\nexport default ImageFloatCard;","C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Utils\\axios.js",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Exam\\QuestionCard\\Order.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Components\\index.js",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Homepage\\Article\\Mobile.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Homepage\\Article\\Desktop.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Exam\\QuestionCard\\Stem.jsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Exam\\QuestionCard\\Answer.jsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Exam\\QuestionCard\\Spent.jsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Apis\\article.js",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Components\\SearchBar\\index.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Homepage\\Article\\partial\\Cate.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Homepage\\Article\\partial\\List.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Homepage\\Article\\partial\\Loadmore.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Components\\Dialog\\index.tsx",[],"C:\\Users\\wangqiang\\Proje