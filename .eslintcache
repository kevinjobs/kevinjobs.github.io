} />\r\n              <Route path=\"/gallery\" component={Gallery} />\r\n              <Route path=\"/\" component={Gallery} />\r\n            </Switch>\r\n          </div>\r\n        </div>\r\n      </Router>\r\n    </ViewportProvider>\r\n  );\r\n}\r\n\r\nexport default App;",["398","399"],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Utils\\viewportContext.js",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Common\\index.js",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\index.js",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Common\\Divider\\index.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Common\\Navbar\\index.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\About\\index.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Homepage\\index.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Exam\\index.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Gallery\\index.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Common\\Footer\\index.jsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Common\\Navbar\\Desktop.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Common\\Navbar\\Moblie.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Exam\\Subject.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Exam\\ChapterCard.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Homepage\\Carousel\\index.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Homepage\\Article\\index.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Exam\\QuestionCard\\index.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Common\\Navbar\\common\\Menu.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Common\\Navbar\\common\\L