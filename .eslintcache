rojects\\kevinjobs.github.io\\src\\Common\\index.js",[],"C:\\Projects\\kevinjobs.github.io\\src\\Apis\\image.js",[],"C:\\Projects\\kevinjobs.github.io\\src\\Pages\\Homepage\\Article\\index.tsx",[],"C:\\Projects\\kevinjobs.github.io\\src\\Pages\\Exam\\QuestionCard\\index.tsx",[],"C:\\Projects\\kevinjobs.github.io\\src\\Utils\\axios.js",[],"C:\\Projects\\kevinjobs.github.io\\src\\Pages\\Homepage\\Article\\Mobile.tsx",[],"C:\\Projects\\kevinjobs.github.io\\src\\Pages\\Homepage\\Article\\Desktop.tsx",["193"],"import React, { createRef } from 'react';\r\nimport ArticleList from './partial/List';\r\nimport FloatCard from './partial/FloatCard';\r\nimport ArticleCate from './partial/Cate';\r\nimport LoadMore from './partial/Loadmore';\r\n\r\nimport { getArticles } from '../../../Apis/article.js';\r\nimport { message } from 'antd';\r\nimport { ArticleType } from '../../Types';\r\n\r\nimport './style.scss';\r\n\r\ninterface ArticleState {\r\n  articles: ArticleType[],\r\n  page: number,\r\n  limit: number,\r\n  more: boolean,\r\n  filter: string,\r\n  index: number,\r\n  mask: boolean\r\n}\r\n\r\nclass DesktopArticle extends React.Component<any, ArticleState> {\r\n  state: ArticleState = {\r\n    articles: [],\r\n    page: 1,\r\n    limit: 8,\r\n    more: true,\r\n    filter: 'all',\r\n    index: -1,\r\n    mask: false\r\n  }\r\n\r\n  private handleClick = (e: any) => {\r\n    const index: number = e.target.attributes.getNamedItem('data-index').value;\r\n    // console.log();\r\n    this.setState({index: index});\r\n    this.setState({mask: true});\r\n  }\r\n\r\n  private onClose = () => {\r\n    // console.log(e);\r\n    this.setState({index: -1});\r\n    this.setState({mask: false});\r\n  }\r\n\r\n  private onFilter = (e: any) => {\r\n    const cate: string = e.target.attributes.getNamedItem('data-cate').value;\r\n    // console.log('selected cate:', cate);\r\n    this.setState({filter: cate});\r\n  }\r\n\r\n  public loadMore = () => {\r\n    // console.log(e)\r\n    if (this.state.more) {\r\n      getArticles(this.state.page+1, this.state.limit).then(res => {\r\n        let data = res.data.data;\r\n        this.setState({articles: this.state.articles.concat(data.items)});\r\n        if (this.state.limit * (this.state.page+1) >= data.total) {\r\n          this.setState({more: false});\r\n          message.warning('最后一页');\r\n        } else {\r\n          this.setState({page: this.state.page + 1})\r\n        }\r\n      })\r\n    }\r\n  }\r\n\r\n  private handleWheel = (e: any) => {\r\n    if (this.state.index !== -1) {\r\n      e.preventDefault();\r\n    }\r\n  }\r\n\r\n  componentDidMount() {\r\n    getArticles(this.state.page, this.state.limit).then(res => {\r\n      let data = res.data.data;\r\n      this.setState({articles: data.items})\r\n    })\r\n    document.body.addEventListener('wheel', this.handleWheel, {passive: false});\r\n  }\r\n\r\n  componentDidUpdate() {\r\n    document.body.removeEventListener('wheel', this.handleWheel);\r\n  }\r\n\r\n  render() {\r\n    const categories = () => {\r\n      let arr: string[] = ['all']\r\n      this.state.articles.map((a) => {\r\n        arr.push(a.category);\r\n        return arr\r\n      })\r\n      return arr\r\n    }\r\n\r\n    const showFloatCard = () => {\r\n      if (this.state.index === -1) {\r\n        return <div></div>\r\n      } else {\r\n        return(\r\n          <FloatCard\r\n            id=\"floatcard\"\r\n            article={this.state.articles[this.state.index]}\r\n            onClose={this.onClose}\r\n          />\r\n        )\r\n      }\r\n    }\r\n\r\n    return(\r\n      <div className=\"desktop-article\">\r\n        <div className=\"article-seperator\"></div>\r\n        <ArticleCate\r\n          categories={categories()}\r\n          filter={this.state.filter}\r\n          onFilter={this.onFilter}\r\n        />\r\n        <ArticleList\r\n          id=\"article-list\"\r\n          articles={this.state.articles}\r\n          filter={this.state.filter}\r\n          onClick={this.handleClick}\r\n        />\r\n        <LoadMore loadmore={this.loadMore} more={this.state.more} />\r\n        { showFloatCard() }\r\n        {\r\n          this.state.mask ? <div className=\"mask fade-in\"></div> : <></>\r\n        }\r\n      </div>\r\n    )\r\n  }\r\n}\r\n\r\nexport default DesktopArticle;","C:\\Projects\\kevinjobs.github.io\\src\\Pages\\Exam\\QuestionCard\\Order.tsx",[],"C:\\Projects\\kevinjobs.github.io\\src\\Pages\\Exam\\QuestionCard\\Answer.jsx",[],"C:\\Projects\\kevinjobs.github.io\\src\\Pages\\Exam\\QuestionCard\\Stem.jsx",[],"C:\\Projects\\kevinjobs.github.io\\src\\Pages\\Exam\\QuestionCard\\Spent.jsx",[],"C:\\Projects\\kevinjobs.github.io\\src\\Apis\\article.js",[],"C:\\Projects\\kevinjobs.github.io\\src\\Common\\MenuButton\\index.tsx",[],"C:\\Projects\\kevinjobs.github.io\\src\\Common\\Navbar\\index.tsx",[],"C:\\Projects\\kevinjobs.github.io\\src\\Common\\Divider\\index.tsx",[],"C:\\Projects\\kevinjobs.github.io\\src\\Common\\Footer\\index.jsx",[],"C:\\Projects\\kevinjobs.github.io\\src\\Pages\\Homepage\\Article\\partial\\FloatCard.tsx",[],"C:\\Projects\\kevinjobs.github.io\\src\\Pages\\Homepage\\Article\\partial\\List.tsx",[],"C:\\Projects\\kevinjobs.github.io\\src\\Pages\\Homepage\\Article\\partial\\Loadmore.tsx",[],"C:\\Projects\\kevinjobs.github.io\\src\\Pages\\Homepage\\Article\\partial\\Cate.tsx",[],"C:\\Projects\\kevinjobs.github.io\\src\\Common\\Navbar\\Moblie.tsx",[],"C:\\Projects\\kevinjobs.github.io\\src\\Common\\Navbar\\Desktop.tsx",[],"C:\\Projects\\kevinjobs.github.io\\src\\Store\\index.js",[],"C:\\Projects\\kevinjobs.github.io\\src\\Store\\actions\\auth-action.js",[],"C:\\Projects\\kevinjobs.github.io\\src\\Store\\types.js",[],"C:\\Projects\\kevinjobs.github.io\\src\\Apis\\auth.js",[],"C:\\Projects\\kevinjobs.github.io\\src\\Store\\reducers\\index.js",[],"C:\\Projects\\kevinjobs.github.io\\src\\Store\\reducers\\auth-reducer.js",[],"C:\\Projects\\kevinjobs.github.io\\src\\Store\\reducers\\reg-reducer.js",[],"C