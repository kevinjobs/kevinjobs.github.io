er\\index.jsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Store\\actions\\auth-action.js",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Components\\Dialog\\LoginDialog.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Store\\types.js",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Store\\index.js",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Apis\\auth.js",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Store\\reducers\\index.js",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Store\\reducers\\auth-reducer.js",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Store\\reducers\\reg-reducer.js",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Store\\reducers\\mask-reducer.js",[],["209","210"],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Components\\Input\\index.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Apis\\post.js",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Homepage\\Article\\Artilce.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Homepage\\Article\\List.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Gallery\\Gallery.tsx",[],"C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Pages\\Gallery\\FloatPanel.tsx",["211"],"import React, { useState } from 'react';\r\nimport { ImageInterface } from './gallery.interface';\r\nimport classNames from 'classnames';\r\n\r\nimport {\r\n  CameraFilled,\r\n  CompassFilled,\r\n  BulbFilled,\r\n  SkinFilled,\r\n  VideoCameraFilled,\r\n  CloseCircleOutlined,\r\n  EnvironmentFilled,\r\n  CalendarFilled,\r\n  CaretLeftFilled,\r\n  CaretRightFilled\r\n} from '@ant-design/icons';\r\n\r\ninterface Props {\r\n  image: ImageInterface,\r\n  onClose?: any,\r\n  onPrev?: any,\r\n  onNext?: any,\r\n  type: number\r\n}\r\n\r\nconst FloatPanel: React.FC<Props> = (props: Props) => {\r\n  const { image } = props;\r\n\r\n  const baseUrl = 'https://mintforge-1252473272.cos.ap-nanjing.myqcloud.com/image/';\r\n\r\n  const handleClick = (e: React.MouseEvent<HTMLElement>) => {\r\n    const { onClose } = props;\r\n    if (onClose) {\r\n      (onClose as React.MouseEventHandler<HTMLElement>)(e);\r\n    }\r\n  }\r\n\r\n  const onPrev = (e: React.MouseEvent<HTMLElement>) => {\r\n    const { onPrev } = props;\r\n    if (onPrev) {\r\n      (onPrev as React.MouseEventHandler<HTMLElement>)(e);\r\n    } \r\n  }\r\n\r\n  const onNext = (e: React.MouseEvent<HTMLElement>) => {\r\n    const { onNext } = props;\r\n    if (onNext) {\r\n      (onNext as React.MouseEventHandler<HTMLElement>)(e);\r\n    } \r\n  }\r\n\r\n  const classnames = classNames({\r\n    \"Gallery-FloatPanel\": true,\r\n    \"Mobile\": props.type === 1 ? true : false,\r\n    \"Desktop\": props.type === 2 ? true : false\r\n  })\r\n\r\n  return(\r\n    <div className={classnames}>\r\n      <div onClick={handleClick.bind(this)} className=\"Gallery-FloatPanel__close\">\r\n        <CloseCircleOutlined />\r\n      </div>\r\n      <div className=\"Gallery-FloatPanel__prev\" onClick={onPrev}><CaretLeftFilled /></div>\r\n      <div className=\"Gallery-FloatPanel__image\">\r\n        <img\r\n          src={baseUrl + image.cover.replace('JPG', 'jpg')}\r\n          alt={image.title}\r\n        />\r\n        <div className=\"Gallery-FloatPanel__image-info\">\r\n          <div className=\"Gallery-FloatPanel__image-info__item\">\r\n            <h2 style={{color:'inherit',margin:'15px 0px'}}>{image.title || '暂无标题'}</h2>\r\n            <p>{image.desc || '暂无描述'}</p>\r\n            <p>{image.author} <SkinFilled /></p>\r\n            <p>{image.exif.exposure_time} <BulbFilled /></p>\r\n            <p>{image.exif.iso} (ISO) <VideoCameraFilled /></p>\r\n            <p>{image.exif.manufacturer} <CameraFilled /> </p>\r\n            <p>{image.exif.address.split('|')[0] || '未知地点'} <CompassFilled /></p>\r\n            <p>{image.exif.address.split('|')[1] || '未知景点'} <EnvironmentFilled /></p>\r\n            <p>{image.exif.datetime} <CalendarFilled /></p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div className=\"Gallery-FloatPanel__next\" onClick={onNext}><CaretRightFilled /></div>\r\n    </div>\r\n  )\r\n}\r\n\r\nexport default FloatPanel;","C:\\Users\\wangqiang\\Projects\\kevinjobs.github.io\\src\\Utils\\index.ts",[],{"ruleId":"212","replacedBy":"213"},{"ruleId":"214","replacedBy":"215"},{"ruleId":"212","replacedBy":"213"},{"ruleId":"214","replacedBy":"215"},{"ruleId":"212","replacedBy":"216"},{"ruleId":"214","replacedBy":"217"},{"ruleId":"212","replacedBy":"216"},{"ruleId":"214","replacedBy":"217"},{"ruleId":"218","severity":1,"message":"219","line":1,"column":17,"nodeType":"220","messageId":"221","endLine":1,"endColumn":25},"no-native-reassign",["222"],"no-negated-in-lhs",["223"],["222"],["223"],"@typescript-eslint/no-unused-vars","'useState' is defined but never used.","Identifier","unusedVar","no-global-assign","no-unsafe-negation"]